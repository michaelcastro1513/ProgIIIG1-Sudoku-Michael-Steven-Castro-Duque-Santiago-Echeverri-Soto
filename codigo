import random
cols = "ABCDEFGHI"
rows = "123456789"
variables = [c+r for r in rows for c in cols]
units = []
units += [[c+r for c in cols] for r in rows]
units += [[c+r for r in rows] for c in cols]
for i in range(3):
for j in range(3):
box = [cols[i*3+x]+rows[j*3+y] for y in range(3) for x in range(3)]
units.append(box)
def create_domains(puzzle):
puzzle = ''.join(c for c in puzzle if c in '0123456789.')
domains = {v:set(range(1,10)) for v in variables}
for i,c in enumerate(puzzle):
if c in '123456789':
domains[variables[i]] = {int(c)}
return domains
def naked(domains, unit):
for v in unit:
if len(domains[v])==1:
val = next(iter(domains[v]))
for w in unit:
if w!=v: domains[w].discard(val)
def hidden(domains, unit):
for v in unit:
if len(domains[v])>1:
for cand in list(domains[v]):
if sum(cand in domains[w] for w in unit)==1:
domains[v]={cand}
break
def propagate(domains):
changed=True
while changed:
changed=False
for unit in units:
naked(domains,unit)
hidden(domains,unit)
if any(len(domains[v])==0 for v in variables):
return False
return True
def solve(domains, depth=0, verbose=True):
unassigned = [v for v in variables if len(domains[v])>1]
if not unassigned:
if verbose: print("\n sudoku resuelto")
return True
var = min(unassigned, key=lambda v:len(domains[v]))
if verbose: print('  '*depth + f"→ {var} ({len(domains[var])})")
backup = {k:set(domains[k]) for k in domains}
for val in sorted(domains[var]):
if verbose: print('  '*depth + f"  probando {var}={val}")
domains[var]={val}
if propagate(domains) and solve(domains,depth+1,verbose):
return True
domains.update(backup)
if verbose: print('  '*depth + f"  backtrack {var}")
return False
def generate_full_board():
grid = [[0]*9 for _ in range(9)]
def bt(pos):
if pos==81: 
return True
r,c = divmod(pos,9)
nums = list(range(1,10))
random.shuffle(nums)
for n in nums:
if all(grid[r][x]!=n for x in range(9)) and all(grid[x][c]!=n for x in range(9)) and all(grid[r//3*3+i][c//3*3+j]!=n for i in range(3) for j in range(3)):
grid[r][c]=n
if bt(pos+1): 
return True
grid[r][c]=0
return False
bt(0)
return grid
def generate_puzzle(difficulty):
clues = {"muy facil":42,"facil":37,"medio":32,"dificil":27,"imposible":22}
num_clues = clues.get(difficulty.lower().replace(" ",""),35)
solved = generate_full_board()
puzzle = [row[:] for row in solved]
cells = list(range(81))
random.shuffle(cells)
for i in range(81-num_clues):
r,c = divmod(cells[i],9)
puzzle[r][c] = 0
return puzzle, solved
