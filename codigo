def interactive_solve(puzzle, solution):
grid = [row[:] for row in puzzle]
print("\n modo resolver")
print("ingresa: casilla valor  (ej: A5 7  o  B3 9)")
print("casillas: A-I (columnas)  1-9 (filas)    o 'q' para salir\n")
while True:
print_board(grid)
if all(all(cell != 0 for cell in row) for row in grid):
print("\n resolviste el sudoku")
break
move = input("movimiento: ").strip().lower()
if move == 'q': 
break
try:
parts = move.split()
if len(parts) != 2: 
raise ValueError
cell = parts[0].upper()
val = int(parts[1])
if len(cell) != 2 or cell[0] not in 'ABCDEFGHI' or cell[1] not in '123456789' or not (1<=val<=9):
raise ValueError
col = 'ABCDEFGHI'.index(cell[0])
row = int(cell[1]) - 1
if puzzle[row][col] != 0:
print(" celda fija (no se puede cambiar)")
continue
if grid[row][col] != 0:
print(" celda ya llena")
continue
if not all(grid[row][x]!=val for x in range(9)) or not all(grid[x][col]!=val for x in range(9)) or not all(grid[row//3*3+i][col//3*3+j]!=val for i in range(3) for j in range(3)):
print(" movimiento invalido - viola reglas")
continue
if solution[row][col] != val:
print(" numero incorrecto")
continue
grid[row][col] = val
print("✓ Correcto")
except:
print(" formato invalido ejemplo: A5 7")
